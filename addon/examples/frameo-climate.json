{
  "name": "HA Light Panel",
  "server": {
    "host": "0.0.0.0",
    "port": 8890,
    "pollMs": 2000
  },
  "homeAssistant": {
    "url": "http://homeassistant.local:8123",
    "browserUrl": "http://homeassistant.local:8123"
  },
  "panel": {
    "title": "Climate Panel",
    "labels": {
      "mode": "Current mode",
      "homeTemp": "Home temp",
      "humidity": "Humidity",
      "comfortBand": "Comfort band",
      "outside": "Outside",
      "rooms": "Rooms & thermostats",
      "target": "Family target"
    },
    "metrics": {
      "roomTemp": "sensor.home_temperature",
      "roomHumidity": "sensor.home_humidity",
      "averageTemp": "sensor.average_temperature",
      "outsideTemp": "sensor.outside_temperature",
      "action": "sensor.hvac_inferred_action"
    },
    "mode": {
      "operatingState": "sensor.hvac_operating_state",
      "miniMode": "climate.mini_split",
      "action": "sensor.mini_split_inferred_action",
      "airflowBoostTimer": "timer.airflow_boost",
      "dryAssistTimer": "timer.dry_assist",
      "postDryFanTimer": "timer.post_dry_fan_purge",
      "automationEnabled": "input_boolean.hvac_automation_enabled",
      "thermostatUnavailable": "binary_sensor.active_thermostat_unavailable",
      "heatDemand": "binary_sensor.heat_demand",
      "coolDemand": "binary_sensor.cool_demand",
      "humidityDemand": "binary_sensor.dehumidify_recommended"
    },
    "comfort": {
      "heatTarget": "sensor.heat_target",
      "coolTarget": "sensor.cool_target",
      "holdActive": "input_boolean.comfort_hold_active",
      "scheduleEnabled": "input_boolean.schedule_enabled",
      "schedulePeriod": "sensor.schedule_period",
      "scheduleProfile": "sensor.schedule_comfort_setting"
    },
    "actions": {
      "cooler": {
        "service": "script.adjust_comfort_temperature",
        "data": { "direction": "down", "step": 1 }
      },
      "warmer": {
        "service": "script.adjust_comfort_temperature",
        "data": { "direction": "up", "step": 1 }
      },
      "reset": {
        "service": "script.reset_comfort_temperature",
        "data": {}
      },
      "assist": {
        "service": "script.start_airflow_assist_now",
        "data": {}
      }
    },
    "statusPanel": {
      "label": "Status",
      "heart": "sensor.status_heart_rate",
      "oxygen": "sensor.status_oxygen",
      "oxygenAverage": "sensor.status_oxygen_average",
      "battery": "sensor.status_battery",
      "remaining": "sensor.status_battery_remaining",
      "signal": "sensor.status_signal_strength",
      "skinTemp": "sensor.status_skin_temperature",
      "sleep": "sensor.status_sleep_state",
      "charging": "binary_sensor.status_charging",
      "sockOff": "binary_sensor.status_not_worn",
      "disconnected": "binary_sensor.status_disconnected",
      "alerts": [
        "binary_sensor.status_alert"
      ]
    },
    "rooms": [
      {
        "id": "living",
        "label": "Living Room",
        "temp": "sensor.living_room_temperature",
        "humidity": "sensor.living_room_humidity",
        "battery": "sensor.living_room_sensor_battery"
      },
      {
        "id": "bedroom",
        "label": "Bedroom",
        "temp": "sensor.bedroom_temperature",
        "humidity": "sensor.bedroom_humidity",
        "battery": "sensor.bedroom_sensor_battery"
      },
      {
        "id": "nursery",
        "label": "Nursery",
        "temp": "sensor.nursery_temperature",
        "humidity": "sensor.nursery_humidity",
        "battery": "sensor.nursery_sensor_battery",
        "extra": {
          "entity": "sensor.nursery_sleep_state",
          "fallback": "Standing by"
        }
      },
      {
        "id": "thermostat",
        "label": "Thermostat",
        "temp": { "entity": "climate.main_thermostat", "attribute": "current_temperature" },
        "humidity": { "entity": "climate.main_thermostat", "attribute": "current_humidity" },
        "extra": {
          "entity": "climate.main_thermostat",
          "hvacModeLabel": true
        }
      },
      {
        "id": "mini_split",
        "label": "Mini Split",
        "temp": { "entity": "climate.mini_split", "attribute": "current_temperature" },
        "miniStatus": {
          "mode": "climate.mini_split",
          "fan": { "entity": "climate.mini_split", "attribute": "fan_mode" },
          "action": "sensor.mini_split_inferred_action"
        }
      },
      {
        "id": "whole_home",
        "label": "Whole Home",
        "temp": "sensor.average_temperature",
        "humidity": "sensor.home_humidity",
        "extra": { "type": "comfortStatus" }
      }
    ]
  },
  "cameraPanel": {
    "alarmEntity": "alarm_control_panel.home_alarm",
    "liveProxyEntity": "binary_sensor.camera_live_proxy",
    "snapshotRefreshPath": "/api/blink_liveview_proxy/cameras/{slug}/snapshot-refresh"
  },
  "cameras": [
    {
      "slug": "driveway",
      "label": "Driveway",
      "sourceEntity": "camera.driveway",
      "liveEntity": "camera.blink_live_driveway",
      "batteryEntity": "binary_sensor.driveway_battery",
      "motionEntity": "binary_sensor.driveway_motion",
      "motionSwitch": "switch.driveway_camera_motion_detection",
      "tempEntity": "sensor.driveway_temperature"
    },
    {
      "slug": "front_door",
      "label": "Front Door",
      "sourceEntity": "camera.front_door",
      "liveEntity": "camera.blink_live_front_door",
      "ignoreBatteryLevel": true,
      "batteryEntity": "binary_sensor.front_door_battery",
      "motionEntity": "binary_sensor.front_door_motion",
      "motionSwitch": "switch.front_door_camera_motion_detection"
    },
    {
      "slug": "powered_camera",
      "label": "Powered Camera",
      "sourceEntity": "camera.powered_camera",
      "liveEntity": "camera.blink_live_powered_camera",
      "powerLabel": "USB power",
      "motionEntity": "binary_sensor.powered_camera_motion",
      "motionSwitch": "switch.powered_camera_motion_detection"
    }
  ]
}
